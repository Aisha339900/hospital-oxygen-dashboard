# ============================================
# Hospital Oxygen Dashboard - Environment Variables
# ============================================
# Copy this file to .env (for root) and frontend/.env (for frontend)
# and fill in the appropriate values.

# --- Backend / API Configuration ---
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/hospital-oxygen-dashboard

# --- Frontend React App Configuration ---
# Set the API base URL (proxied to localhost:5000 in development via package.json proxy)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_NODE_ENV=development

# App metadata
REACT_APP_APP_NAME=Hospital Oxygen Dashboard
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_REAL_TIME_UPDATES=true
REACT_APP_REAL_TIME_REFRESH_INTERVAL=5000

# Alarm refresh interval (ms)
REACT_APP_ALARM_REFRESH_INTERVAL=3000
REACT_APP_ALERT_SOUND_ENABLED=false

# Chart settings
REACT_APP_CHART_ANIMATION_ENABLED=true
REACT_APP_CHART_RESPONSIVE=true

# Logging
REACT_APP_LOG_LEVEL=info
REACT_APP_ENABLE_CONSOLE_LOGGING=true

# Optional: N8N Chat Webhook for ChatWidget
REACT_APP_N8N_CHAT_WEBHOOK=
